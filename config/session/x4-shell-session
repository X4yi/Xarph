#!/bin/sh
# X4Shell Session Script
# Sets up environment and starts all components

# Set session environment for Wayland and greeter compatibility
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=X4Shell
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# Ensure D-Bus session is available (greeter should provide it, but verify)
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    eval $(dbus-launch --sh-syntax)
fi

# Update systemd activation environment
dbus-update-activation-environment --systemd DISPLAY XAUTHORITY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE >/dev/null 2>&1 || true

# Find daemon binary
DAEMON_PATH="@DAEMON_PATH@"
if [ ! -x "$DAEMON_PATH" ]; then
    DAEMON_PATH="$HOME/.local/bin/x4shell-daemon"
fi
if [ ! -x "$DAEMON_PATH" ]; then
    echo "x4shell-daemon not found" >&2
    exit 1
fi

# Start daemon in background
$DAEMON_PATH &
DAEMON_PID=$!

# Wait for daemon to start and register on D-Bus
sleep 2

# Start UI using quickshell with correct path flag (-p for path)
quickshell -p "@UI_PATH@" &
UI_PID=$!

# Start Hyprland (takes over session as foreground process)
exec Hyprland --config "$XDG_CONFIG_HOME/x4-shell/hypr/hyprland.conf"
